          },
          "response": []
        },
        {
          "name": "Eliminar libro",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/libros/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "libros", "1"]
            },
            "description": "Elimina un libro por id."
          },
          "response": []
        },
        {
          "name": "Libros con nacionalidad del autor (DTO)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/libros/con-nacionalidad",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "libros", "con-nacionalidad"]
            },
            "description": "Retorna una lista proyectada con solo el título del libro y la nacionalidad de su autor (LibroNacionalidadDTO). Ejemplo de respuesta:\n[\n  { \"titulo\": \"Cien años de soledad\", \"nacionalidadAutor\": \"Colombiana\" },\n  { \"titulo\": \"La casa de los espíritus\", \"nacionalidadAutor\": \"Chilena\" }\n]"
          },
          "response": []
        },
        {
          "name": "[TEST] Error controlado por GlobalExceptionHandler",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/libros/test-error",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "libros", "test-error"]
            },
            "description": "Endpoint de prueba que lanza una RuntimeException a propósito. Demuestra cómo el GlobalExceptionHandler intercepta el error y devuelve un JSON estructurado con código 500:\n{\n  \"codigo\": 500,\n  \"mensaje\": \"Error interno del servidor\",\n  \"detalle\": \"Este es un error de prueba lanzado intencionalmente\"\n}"
          },
          "response": []
        }
      ]
    }
  ],
