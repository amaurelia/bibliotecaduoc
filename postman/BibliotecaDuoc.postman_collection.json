      "item": [
        {
          "name": "Listar libros",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/libros",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "libros"]
            },
            "description": "Retorna todos los libros."
          },
          "response": []
        },
        {
          "name": "Buscar libro por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/libros/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "libros", "1"]
            },
            "description": "Busca un libro por id."
          },
          "response": []
        },
        {
          "name": "Crear libro",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isbn\": \"9789561234567\",\n  \"titulo\": \"Clean Code\",\n  \"editorial\": \"Prentice Hall\",\n  \"fechaPublicacion\": 2008,\n  \"autor\": {\n    \"id\": 1\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/libros",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "libros"]
            },
            "description": "Crea un libro nuevo. El campo autor.id debe corresponder a un autor existente."
          },
          "response": []
        },
        {
          "name": "Actualizar libro",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isbn\": \"9789561234567\",\n  \"titulo\": \"Clean Code (Edicion actualizada)\",\n  \"editorial\": \"Prentice Hall\",\n  \"fechaPublicacion\": 2009,\n  \"autor\": {\n    \"id\": 1\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/libros/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "libros", "1"]
