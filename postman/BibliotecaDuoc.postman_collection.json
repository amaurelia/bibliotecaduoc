  },
  "item": [
    {
      "name": "Autores",
      "item": [
        {
          "name": "Listar autores",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/autores",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "autores"]
            },
            "description": "Retorna todos los autores."
          },
          "response": []
        },
        {
          "name": "Buscar autor por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/autores/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "autores", "1"]
            },
            "description": "Busca un autor por id."
          },
          "response": []
        },
        {
          "name": "Crear autor",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Robert C. Martin\",\n  \"edad\": 73,\n  \"nacionalidad\": \"Estadounidense\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/autores",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "autores"]
            },
            "description": "Crea un autor nuevo. Guarda el id que devuelva para usarlo al crear un libro."
          },
          "response": []
        },
        {
          "name": "Actualizar autor",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Robert C. Martin\",\n  \"edad\": 74,\n  \"nacionalidad\": \"Estadounidense\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/autores/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "autores", "1"]
            },
            "description": "Actualiza un autor existente por id."
          },
          "response": []
        },
        {
          "name": "Eliminar autor",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/autores/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "autores", "1"]
            },
            "description": "Elimina un autor por id."
          },
          "response": []
        }
      ]
    },
    {
